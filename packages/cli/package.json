{
  "name": "@glinr/theauth-cli",
  "version": "0.1.4",
  "description": "TheAuth CLI - setup wizard, dashboard launcher, and development tools",
  "type": "module",
  "bin": {
    "theauth": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@glinr/theauth": "workspace:*",
    "@glinr/theauth-hono": "workspace:*",
    "hono": "^4.12.27",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "theauth",
    "auth",
    "agent",
    "cli"
  ],
  "author": "TheAuth <support@glincker.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glincker/theauth.git",
    "directory": "packages/cli"
  }
}
