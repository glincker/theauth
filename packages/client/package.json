{
  "name": "@glinr/theauth-client",
  "version": "0.2.0",
  "description": "TypeScript client for the TheAuth REST API",
  "license": "MIT",
  "author": "TheAuth <support@glincker.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/glincker/theauth.git",
    "directory": "packages/client"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
