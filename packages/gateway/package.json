{
  "name": "@theauth/gateway",
  "version": "3.0.2",
  "description": "Standalone auth proxy for TheAuth - enforces auth, authorization, and audit in front of any API or MCP server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "theauth-gateway": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "theauth",
    "gateway",
    "proxy",
    "auth",
    "agent",
    "mcp",
    "middleware"
  ],
  "author": "TheAuth <support@glincker.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glincker/theauth.git",
    "directory": "packages/gateway"
  },
  "dependencies": {
    "micromatch": "^4.0.8"
  },
  "peerDependencies": {
    "theauth": "workspace:*",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "theauth": "workspace:*",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
