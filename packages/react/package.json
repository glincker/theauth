{
  "name": "@kavachos/react",
  "version": "0.5.0",
  "description": "React hooks for KavachOS auth (with v0.5 session rotation)",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "license": "MIT",
  "author": "KavachOS <support@glincker.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/kavachos/kavachos.git",
    "directory": "packages/react"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "jsdom": "^29.0.1",
    "@types/react": "^19.0.0",
    "vitest": "^4.1.5",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  }
}
