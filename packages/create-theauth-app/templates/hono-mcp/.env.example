# Long random string used to sign sessions and access tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
THEAUTH_SECRET=

# Signing secret for MCP JWT access tokens. Must be at least 32 chars.
MCP_SIGNING_SECRET=change-me-to-a-real-secret-at-least-32-chars

# Database driver. Set to "postgres" to use Postgres instead of local SQLite.
DB_PROVIDER=sqlite

# Database URL. Defaults match DB_PROVIDER.
# SQLite:   file:./kavach.db
# Postgres: postgres://user:pass@host:5432/dbname
DATABASE_URL=__DB_URL__

# Base URL the server is reachable at. Appears in .well-known documents and
# access-token claims. Change to your public URL before deploying.
BASE_URL=http://localhost:3001

# Port to listen on.
PORT=3001
