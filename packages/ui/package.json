  },
  "devDependencies": {
    "@theauth/react": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  }
