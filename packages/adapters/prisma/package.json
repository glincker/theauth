{
  "name": "@glinr/theauth-prisma",
  "version": "3.0.3",
  "description": "Prisma database adapter for TheAuth - use PrismaClient as your TheAuth database backend",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/schema.prisma"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "theauth",
    "prisma",
    "auth",
    "agent",
    "database",
    "adapter"
  ],
  "author": "TheAuth <support@glincker.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glincker/theauth.git",
    "directory": "packages/adapters/prisma"
  },
  "peerDependencies": {
    "@glinr/theauth": "workspace:*",
    "@prisma/client": ">=5.0.0"
  },
  "devDependencies": {
    "@glinr/theauth": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
