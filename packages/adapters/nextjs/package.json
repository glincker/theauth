{
  "name": "@glinr/theauth-nextjs",
  "version": "3.0.2",
  "description": "Next.js App Router adapter for TheAuth - exposes agent auth as HTTP REST endpoints",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "theauth",
    "nextjs",
    "auth",
    "agent",
    "mcp"
  ],
  "author": "TheAuth <support@glincker.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glincker/theauth.git",
    "directory": "packages/adapters/nextjs"
  },
  "peerDependencies": {
    "@glinr/theauth": "workspace:*",
    "next": ">=14.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@glinr/theauth": "workspace:*",
    "next": "^15.0.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
