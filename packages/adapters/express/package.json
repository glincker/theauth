{
  "name": "@glinr/theauth-express",
  "version": "3.1.0",
  "description": "Express adapter for TheAuth - exposes agent auth as HTTP REST endpoints",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "theauth",
    "express",
    "auth",
    "agent",
    "mcp"
  ],
  "author": "TheAuth <support@glincker.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glincker/theauth.git",
    "directory": "packages/adapters/express"
  },
  "peerDependencies": {
    "@glinr/theauth": "workspace:*",
    "express": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@glinr/theauth": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.0",
    "express": "^5.1.0",
    "supertest": "^7.0.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
