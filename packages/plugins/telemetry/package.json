{
  "name": "@kavachos/plugin-telemetry",
  "version": "3.0.2",
  "description": "OpenTelemetry integration plugin for KavachOS — converts auth events into OTel spans",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "kavachos",
    "telemetry",
    "opentelemetry",
    "otel",
    "auth",
    "agent"
  ],
  "author": "KavachOS <support@glincker.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kavachos/kavachos.git",
    "directory": "packages/plugins/telemetry"
  },
  "peerDependencies": {
    "kavachos": "workspace:*"
  },
  "devDependencies": {
    "kavachos": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^12.9.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}
