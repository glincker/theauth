{
  "name": "@glinr/theauth-expo",
  "version": "0.1.0",
  "description": "React Native / Expo client for TheAuth auth",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "license": "MIT",
  "author": "TheAuth <support@glincker.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/glincker/theauth.git",
    "directory": "packages/expo"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "jsdom": "^29.0.1",
    "@types/react": "^19.0.0",
    "vitest": "^4.1.9",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  }
}
