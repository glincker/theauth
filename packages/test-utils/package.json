{
  "name": "@glinr/theauth-test-utils",
  "version": "0.1.0",
  "description": "Test utilities for TheAuth — mock providers, factories, and assertions for auth test suites",
  "license": "MIT",
  "author": "TheAuth <support@glincker.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/glincker/theauth.git",
    "directory": "packages/test-utils"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@glinr/theauth-react": ">=0.0.1",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@glinr/theauth-react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@glinr/theauth-react": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}
