# Long random string used to sign sessions and access tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KAVACHOS_SECRET=

# Database connection. Defaults to a local SQLite file if unset.
# Postgres example: postgres://user:pass@host:5432/dbname
DATABASE_URL=__DB_URL__

# Base URL that this server is reachable at. Appears in MCP .well-known
# documents and in issued access-token claims. Change to your public URL
# before deploying.
BASE_URL=http://localhost:3001
