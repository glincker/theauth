{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "KavachOS",
  "description": "Auth OS for AI agents. TypeScript SDK for agent identity, permissions, delegation, audit, and MCP OAuth 2.1.",
  "colors": {
    "primary": "#C9A84C",
    "light": "#E0C56A",
    "dark": "#8B6914"
  },
  "background": {
    "decoration": "gradient"
  },
  "favicon": "/favicon.png",
  "styling": {
    "codeblocks": "system"
  },
  "css": "/styles/custom.css",
  "logo": {
    "light": "/logo/wordmark-light.svg",
    "dark": "/logo/wordmark-dark.svg",
    "href": "https://kavachos.com"
  },
  "fonts": {
    "heading": { "family": "Inter" },
    "body": { "family": "Inter" }
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "metadata": {
    "timestamp": true
  },
  "search": {
    "prompt": "Search docs, agents, or standards"
  },
  "interaction": {
    "drilldown": true
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "mcp"
    ]
  },
  "banner": {
    "content": "KavachOS v0.4.2 is out. [Install](/quickstart) or [star on GitHub](https://github.com/kavachos/kavachos).",
    "dismissible": true
  },
  "errors": {
    "404": {
      "title": "Page not found",
      "description": "This page moved or never existed. Head to the [quickstart](/quickstart) or search above.",
      "redirect": false
    }
  },
  "navbar": {
    "links": [
      { "label": "Changelog", "icon": "clock-rotate-left", "href": "https://github.com/kavachos/kavachos/releases" },
      { "label": "GitHub", "icon": "github", "href": "https://github.com/kavachos/kavachos" }
    ],
    "primary": {
      "type": "button",
      "label": "npm i kavachos",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/kavachos/kavachos",
      "x": "https://x.com/thegdsks",
      "website": "https://kavachos.com"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "KavachOS",
      "og:type": "website"
    },
    "indexing": "navigable"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Get started",
        "icon": "rocket",
        "groups": [
          {
            "group": "Start here",
            "icon": "flag",
            "pages": ["index", "concepts", "quickstart"]
          },
          {
            "group": "Setup",
            "icon": "wrench",
            "pages": ["add-to-existing-app", "configuration", "database"]
          },
          {
            "group": "Sessions",
            "icon": "stopwatch",
            "pages": ["sessions", "jwt-sessions", "cookies", "one-time-tokens"]
          }
        ]
      },
      {
        "tab": "Authentication",
        "icon": "key",
        "groups": [
          {
            "group": "Overview",
            "icon": "circle-info",
            "pages": ["auth/index", "last-login"]
          },
          {
            "group": "Methods",
            "icon": "door-open",
            "pages": [
              {
                "group": "Password",
                "icon": "key",
                "pages": ["auth/email-password", "auth/username"]
              },
              {
                "group": "Passwordless",
                "icon": "wand-magic-sparkles",
                "pages": [
                  "auth/magic-link",
                  "auth/email-otp",
                  "auth/phone",
                  "auth/passkey",
                  "auth/siwe",
                  "auth/device"
                ]
              },
              {
                "group": "MFA and anti-abuse",
                "icon": "shield-check",
                "pages": ["auth/two-factor", "auth/captcha"]
              },
              {
                "group": "Other",
                "icon": "ellipsis",
                "pages": ["auth/anonymous", "auth/one-tap", "auth/oauth-proxy"]
              }
            ]
          },
          {
            "group": "OAuth providers",
            "icon": "plug",
            "pages": [
              "auth/oauth",
              {
                "group": "Popular",
                "icon": "star",
                "pages": [
                  "auth/google",
                  "auth/github",
                  "auth/apple",
                  "auth/microsoft",
                  "auth/discord",
                  "auth/slack",
                  "auth/linkedin"
                ]
              },
              {
                "group": "Social",
                "icon": "users",
                "pages": [
                  "auth/facebook",
                  "auth/spotify",
                  "auth/twitch",
                  "auth/reddit",
                  "auth/twitter",
                  "auth/tiktok",
                  "auth/kakao",
                  "auth/naver",
                  "auth/vk",
                  "auth/line",
                  "auth/wechat",
                  "auth/kick",
                  "auth/roblox"
                ]
              },
              {
                "group": "Work and productivity",
                "icon": "briefcase",
                "pages": [
                  "auth/notion",
                  "auth/figma",
                  "auth/dropbox",
                  "auth/zoom",
                  "auth/atlassian",
                  "auth/linear",
                  "auth/gitlab",
                  "auth/bitbucket",
                  "auth/salesforce"
                ]
              },
              {
                "group": "Developer platforms",
                "icon": "cloud",
                "pages": [
                  "auth/vercel",
                  "auth/railway",
                  "auth/huggingface"
                ]
              },
              {
                "group": "Payments and crypto",
                "icon": "wallet",
                "pages": [
                  "auth/paypal",
                  "auth/coinbase",
                  "auth/polar"
                ]
              },
              {
                "group": "Enterprise IdPs",
                "icon": "building-shield",
                "pages": [
                  "auth/auth0",
                  "auth/okta",
                  "auth/yahoo"
                ]
              }
            ]
          },
          {
            "group": "Enterprise",
            "icon": "building",
            "pages": [
              "auth/organizations",
              "auth/sso",
              "auth/admin",
              "auth/api-keys",
              "auth/stripe",
              "auth/polar-payment",
              "auth/scim",
              "auth/oidc-provider"
            ]
          }
        ]
      },
      {
        "tab": "Agents",
        "icon": "robot",
        "groups": [
          {
            "group": "Identity",
            "icon": "fingerprint",
            "pages": ["agents", "ephemeral-sessions", "delegation"]
          },
          {
            "group": "Authorization",
            "icon": "shield-halved",
            "pages": ["permissions", "policy-engine", "rebac", "policies/templates"]
          },
          {
            "group": "Observability",
            "icon": "chart-line",
            "pages": ["audit", "analyzer", "trust", "anomaly"]
          },
          {
            "group": "Controls",
            "icon": "gauge",
            "pages": [
              "approval",
              "rate-limiting",
              "budget-policies",
              "cost-attribution"
            ]
          }
        ]
      },
      {
        "tab": "Platform",
        "icon": "layer-group",
        "groups": [
          {
            "group": "MCP and gateway",
            "icon": "network-wired",
            "pages": ["mcp", "gateway"]
          },
          {
            "group": "Framework adapters",
            "icon": "puzzle-piece",
            "pages": [
              "adapters/index",
              {
                "group": "Server frameworks",
                "icon": "server",
                "pages": [
                  "adapters/hono",
                  "adapters/express",
                  "adapters/fastify",
                  "adapters/nestjs"
                ]
              },
              {
                "group": "Meta-frameworks",
                "icon": "window-restore",
                "pages": [
                  "adapters/nextjs",
                  "adapters/nuxt",
                  "adapters/sveltekit",
                  "adapters/solidstart",
                  "adapters/tanstack",
                  "adapters/astro"
                ]
              }
            ]
          },
          {
            "group": "Client SDKs",
            "icon": "code",
            "pages": [
              "client-sdk",
              "react",
              "vue",
              "svelte",
              "expo",
              "electron",
              "ui-components",
              "dashboard"
            ]
          },
          {
            "group": "Infra",
            "icon": "server",
            "pages": ["terraform", "prisma"]
          }
        ]
      },
      {
        "tab": "Advanced",
        "icon": "sliders",
        "groups": [
          {
            "group": "Compliance and security",
            "icon": "scale-balanced",
            "pages": ["compliance", "gdpr", "hibp", "trusted-device", "multi-session"]
          },
          {
            "group": "Lifecycle",
            "icon": "arrows-spin",
            "pages": [
              "hooks",
              "webhooks",
              "event-streaming",
              "custom-session",
              "additional-fields",
              "email-templates",
              "i18n"
            ]
          },
          {
            "group": "Identity primitives",
            "icon": "user-shield",
            "pages": ["did", "verifiable-credentials", "federation", "multi-tenant"]
          },
          {
            "group": "Standards",
            "icon": "book-open",
            "pages": ["standards"]
          }
        ]
      },
      {
        "tab": "Migrate",
        "icon": "arrow-right-arrow-left",
        "groups": [
          {
            "group": "Migration guides",
            "icon": "arrow-right-arrow-left",
            "pages": [
              "migrate/index",
              "migrate/from-better-auth",
              "migrate/from-clerk"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "icon": "book",
        "groups": [
          {
            "group": "API",
            "icon": "code-branch",
            "pages": ["api", "errors", "test-utils", "a2a"]
          }
        ]
      },
      {
        "tab": "Compare",
        "icon": "code-compare",
        "groups": [
          {
            "group": "Comparisons",
            "icon": "code-compare",
            "pages": [
              "compare/index",
              "compare/vs-ba",
              "compare/vs-hanko",
              "compare/vs-casdoor",
              "compare/vs-paid"
            ]
          }
        ]
      }
    ]
  }
}
