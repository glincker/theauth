{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "KavachOS",
  "description": "Auth OS for AI agents. TypeScript SDK for agent identity, permissions, delegation, audit, and MCP OAuth 2.1.",
  "colors": {
    "primary": "#C9A84C",
    "light": "#E0C56A",
    "dark": "#8B6914"
  },
  "background": {
    "decoration": "gradient"
  },
  "favicon": "/favicon.png",
  "styling": {
    "codeblocks": "system"
  },
  "css": "/styles/custom.css",
  "logo": {
    "light": "/logo/wordmark-light.svg",
    "dark": "/logo/wordmark-dark.svg",
    "href": "https://kavachos.com"
  },
  "styling": {
    "codeblocks": "system"
  },
  "fonts": {
    "heading": { "family": "Inter" },
    "body": { "family": "Inter" }
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "navbar": {
    "links": [
      { "label": "Site", "href": "https://kavachos.com" },
      { "label": "GitHub", "href": "https://github.com/kavachos/kavachos" }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/kavachos/kavachos",
      "x": "https://x.com/thedsks",
      "website": "https://kavachos.com"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "KavachOS",
      "og:type": "website"
    },
    "indexing": "navigable"
  },
