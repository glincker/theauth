{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "KavachOS",
  "description": "Auth OS for AI agents. TypeScript SDK for agent identity, permissions, delegation, audit, and MCP OAuth 2.1.",
  "colors": {
    "primary": "#C9A84C",
    "light": "#D4B870",
    "dark": "#8B6914"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo.svg",
    "href": "https://kavachos.com"
  },
  "fonts": {
    "heading": { "family": "Inter" },
    "body": { "family": "Inter" },
    "code": { "family": "JetBrains Mono" }
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "navbar": {
    "links": [
      { "label": "GitHub", "href": "https://github.com/kavachos/kavachos" }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/kavachos/kavachos",
      "x": "https://x.com/thedsks"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "KavachOS",
      "og:type": "website"
    },
    "indexing": "navigable"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
